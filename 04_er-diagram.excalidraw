    {
      "id": "EkOcuuTUfKo-gaYBBzRfB",
      "type": "text",
      "x": 558.997675543219,
      "y": 504.35958116201175,
      "width": 986.8654905442254,
      "height": 539.7101000990541,
      "angle": 0,
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aT",
